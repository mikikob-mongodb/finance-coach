# MongoDB Atlas connection string
# Get yours from: Atlas UI → Connect → Drivers → Copy connection string
# Replace <user>, <pass>, and <cluster> with your values
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/

# Database name (no need to change for the demo)
MONGODB_DATABASE=finance_coach_db

# Voyage AI API key
# Get yours from: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=vo-...

# Anthropic API key
# Get yours from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...